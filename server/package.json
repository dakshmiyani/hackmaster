{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:worker": "nodemon worker.js",
    "dev:all": "npm run dev & npm run dev:worker",
    "migrate:make": "knex migrate:make --knexfile knexfile.js",
    "migrate:latest": "knex migrate:latest --knexfile knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.js",
    "migrate:status": "knex migrate:status --knexfile knexfile.js",
    "seed:make": "knex seed:make --knexfile knexfile.js",
    "seed:run": "knex seed:run --knexfile knexfile.js",
    "db:reset": "knex migrate:rollback --all && knex migrate:latest && knex seed:run",
    "run_next_migration": "knex migrate:up --migrations-directory src/models/migrations",
    "undo_last_migration": "knex migrate:down--migrations-directory src/models/migrations",
    "create_migration": "knex migrate:make  src/models/migrations"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "bullmq": "^5.71.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-fileupload": "^1.5.2",
    "express-jwt": "^8.5.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "joi": "^18.0.2",
    "knex": "^3.1.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemon": "^3.1.14",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0"
  }
}
